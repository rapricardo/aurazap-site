---
import { ShieldCheck, Lock, Shield } from '@lucide/astro';
---

<section id="seguranca" class="py-24 bg-slate-950 border-t border-slate-900">
  <div class="max-w-7xl mx-auto px-6">
    <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-8 md:p-12 lg:p-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left content -->
        <div class="space-y-8">
          <div class="w-14 h-14 bg-target-green/10 rounded-2xl flex items-center justify-center">
            <ShieldCheck class="w-7 h-7 text-target-green" />
          </div>

          <div class="space-y-4">
            <h2 class="text-3xl md:text-4xl leading-tight">
              Sua conta segura e protegida
            </h2>
            <p class="text-slate-400 text-lg leading-relaxed">
              Utilizamos tecnologia de ponta para garantir que sua conta permaneça segura durante toda a operação. Nosso sistema opera dentro dos limites seguros, simulando comportamento humano natural.
            </p>
          </div>

          <div class="space-y-5">
            <!-- Feature 1 -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-slate-800 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
                <Lock class="w-5 h-5 text-target-green" />
              </div>
              <div>
                <h3 class="text-white font-semibold text-base mb-1">Criptografia de ponta a ponta</h3>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Todos os dados são criptografados em trânsito e em repouso, garantindo privacidade total das suas informações.
                </p>
              </div>
            </div>

            <!-- Feature 2 -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-slate-800 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
                <Shield class="w-5 h-5 text-target-green" />
              </div>
              <div>
                <h3 class="text-white font-semibold text-base mb-1">Algoritmo anti-banimento</h3>
                <p class="text-slate-400 text-sm leading-relaxed">
                  Nosso sistema inteligente respeita os limites da plataforma, evitando qualquer risco para sua conta.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right decorative card -->
        <div class="relative flex items-center justify-center">
          <!-- Green glow -->
          <div class="absolute inset-0 bg-target-green/5 rounded-3xl blur-2xl"></div>

          <div class="relative w-full max-w-sm mx-auto bg-slate-800/60 border border-slate-700 rounded-2xl p-8 space-y-6">
            <!-- Header -->
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full bg-target-green animate-pulse"></div>
              <span class="text-sm text-slate-300 font-medium">Monitoramento Seguro</span>
            </div>

            <!-- Status bar -->
            <div class="bg-slate-900/80 rounded-xl p-4 border border-slate-700/50">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs text-slate-500 uppercase tracking-wider">Status</span>
                <span class="text-xs text-target-green font-semibold">Ativo</span>
              </div>
              <div class="w-full h-2 bg-slate-700 rounded-full overflow-hidden">
                <div class="h-full w-4/5 bg-gradient-to-r from-target-green to-target-green/60 rounded-full"></div>
              </div>
            </div>

            <!-- Protected badge -->
            <div class="flex items-center gap-3 bg-target-green/10 border border-target-green/20 rounded-xl p-4">
              <ShieldCheck class="w-5 h-5 text-target-green shrink-0" />
              <span class="text-sm text-target-green font-medium">
                Status: Protegido por Target AI
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
