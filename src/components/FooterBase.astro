---
import { ArrowRight } from '@lucide/astro';
---

<footer class="relative border-t border-white/5 overflow-hidden">
  <!-- Green glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-target-green/10 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- CTA -->
  <div class="py-20 text-center max-w-4xl mx-auto px-6 relative z-10">
    <h2 class="text-3xl md:text-5xl leading-tight mb-8">
      Chega de ser escravo das notificações.<br />
      <span class="text-target-green">Deixe o Target AI trabalhar.</span>
    </h2>
    <a
      href="https://app.target-ia.com/login"
      class="btn-primary cta-link text-lg"
    >
      EXPERIMENTAR TARGET AI AGORA
      <ArrowRight class="w-5 h-5" />
    </a>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5 py-8 px-6 relative z-10">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline">
        <img src="/target-logo.png" alt="Target AI" class="h-7 w-auto" />
      </a>

      <!-- Copyright -->
      <span class="text-slate-500 text-sm text-center">
        &copy; 2026 Target AI - Captura inteligente de leads. Todos os direitos reservados.
      </span>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm">
        <a href="/privacidade" class="text-slate-500 hover:text-slate-300 transition-colors no-underline">
          Privacidade
        </a>
        <a href="/termos" class="text-slate-500 hover:text-slate-300 transition-colors no-underline">
          Termos
        </a>
      </div>
    </div>
  </div>
</footer>
