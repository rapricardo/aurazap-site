---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavbarGemini from '../components/NavbarGemini.astro';
import SecuritySection from '../components/SecuritySection.astro';
import FooterBase from '../components/FooterBase.astro';
import { Zap, Clock, Smartphone, TrendingDown, Target, ArrowRight } from '@lucide/astro';
---

<BaseLayout
  title="Target AI — Automação Inteligente 24/7 para WhatsApp"
  description="Pare de perder horas lendo conversas. O Target AI identifica intenções de compra em tempo real e aborda o lead no direct para você. Setup em 2 minutos."
>
  <NavbarGemini />

  <div class="bg-slate-950 text-white min-h-screen pt-20">

    <!-- ==================== HERO ==================== -->
    <section class="relative overflow-hidden py-24 lg:py-32 px-4">
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 items-center">

        <!-- Lado esquerdo -->
        <div class="flex-1 space-y-6">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 bg-target-green/10 border border-target-green/20 text-target-green rounded-full px-4 py-2 text-sm font-medium">
            <Zap class="w-4 h-4" />
            Automação Inteligente 24/7
          </div>

          <h1 class="text-4xl lg:text-6xl font-extrabold leading-tight">
            Sua IA de vendas que monitora grupos de WhatsApp <span class="text-target-green">24/7.</span>
          </h1>

          <p class="text-lg text-slate-400 leading-relaxed max-w-xl">
            Pare de perder horas lendo conversas. O Target AI identifica intenções de compra em tempo real e aborda o lead no direct para você.
          </p>

          <div>
            <a
              href="https://app.target-ia.com/login"
              class="cta-link inline-flex items-center gap-2 bg-target-green hover:bg-target-green-hover text-white px-8 py-4 rounded-xl font-bold text-lg transition-colors"
            >
              ATIVAR MEUS 7 DIAS GRÁTIS
              <ArrowRight class="w-5 h-5" />
            </a>

            <div class="flex items-center gap-4 mt-4 text-xs text-slate-500">
              <span>✓ Sem cartão de crédito</span>
              <span>✓ Setup em 2 minutos</span>
            </div>
          </div>
        </div>

        <!-- Lado direito — Mock UI -->
        <div class="flex-1 relative">
          <!-- Glow verde atrás -->
          <div class="absolute -inset-4 bg-target-green/20 rounded-3xl blur-3xl"></div>

          <div class="relative bg-slate-900 border border-slate-800 p-2 rounded-2xl shadow-2xl">
            <div class="bg-slate-950 rounded-xl border border-slate-800">
              <!-- Header bar -->
              <div class="h-12 bg-slate-900 rounded-t-xl flex items-center gap-2 px-4">
                <div class="w-3 h-3 rounded-full bg-red-500/20"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/20"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/20"></div>
                <span class="ml-3 text-xs text-slate-500 font-medium">Target AI Engine</span>
              </div>

              <!-- Chat feed mockup -->
              <div class="p-6 space-y-4">
                <!-- Mensagem do grupo -->
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center shrink-0">
                    <span class="text-xs text-blue-400 font-bold">JM</span>
                  </div>
                  <div class="bg-slate-800 rounded-xl rounded-tl-none px-4 py-3 max-w-[85%]">
                    <span class="text-sm text-slate-300">Alguém aqui indica um escritório de contabilidade confiável?</span>
                  </div>
                </div>

                <!-- Status de captura -->
                <div class="flex items-center gap-2 px-4 py-2">
                  <span class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-target-green opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-target-green"></span>
                  </span>
                  <span class="text-xs text-target-green font-semibold">Capturando Lead...</span>
                </div>

                <!-- Resposta da IA -->
                <div class="flex items-start gap-3 justify-end">
                  <div class="bg-target-green/20 rounded-xl rounded-tr-none px-4 py-3 max-w-[85%]">
                    <span class="text-sm text-white">Olá! Vi que você busca contabilidade. Sou da X-Contábil e...</span>
                  </div>
                  <div class="w-8 h-8 rounded-full bg-target-green/20 flex items-center justify-center shrink-0">
                    <Target class="w-4 h-4 text-target-green" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PROBLEM ==================== -->
    <section class="py-24 bg-slate-900/50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-4xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl lg:text-5xl leading-tight mb-6">
            Grupos de WhatsApp são minas de ouro,<br />
            <span class="text-target-green">mas ninguém tem tempo de minerar.</span>
          </h2>
          <p class="text-lg text-slate-400 leading-relaxed max-w-2xl mx-auto">
            Você gasta energia com notificações irrelevantes enquanto os clientes reais passam despercebidos.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Card 1 -->
          <div class="bg-slate-950 p-8 rounded-2xl border border-slate-800 hover:border-target-green/40 transition-all duration-300">
            <div class="w-12 h-12 bg-red-500/10 rounded-xl flex items-center justify-center mb-6">
              <Clock class="w-6 h-6 text-red-500" />
            </div>
            <h3 class="text-xl font-semibold mb-3">Oportunidades Perdidas</h3>
            <p class="text-slate-400 leading-relaxed">
              Leads que esfriam porque você demorou horas para ver a mensagem no meio do caos.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="bg-slate-950 p-8 rounded-2xl border border-slate-800 hover:border-target-green/40 transition-all duration-300">
            <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center mb-6">
              <Smartphone class="w-6 h-6 text-orange-500" />
            </div>
            <h3 class="text-xl font-semibold mb-3">Exaustão Digital</h3>
            <p class="text-slate-400 leading-relaxed">
              Ler centenas de mensagens inúteis por dia só para tentar encontrar um cliente.
            </p>
          </div>

          <!-- Card 3 -->
          <div class="bg-slate-950 p-8 rounded-2xl border border-slate-800 hover:border-target-green/40 transition-all duration-300">
            <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center mb-6">
              <TrendingDown class="w-6 h-6 text-yellow-500" />
            </div>
            <h3 class="text-xl font-semibold mb-3">Timing Errado</h3>
            <p class="text-slate-400 leading-relaxed">
              Chegar no lead quando a concorrência já fechou ou o cliente já perdeu o interesse.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== STEPS ==================== -->
    <section id="como-funciona" class="py-24 px-4 max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl lg:text-5xl text-center leading-tight mb-16">
        Configuração em <span class="text-target-green">3 passos</span>
      </h2>

      <div class="space-y-16">
        <!-- Passo 1 -->
        <div class="group flex flex-col md:flex-row items-center gap-8">
          <div class="w-16 h-16 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0 group-hover:bg-target-green group-hover:text-white transition-colors">
            <span class="text-2xl font-black text-target-green group-hover:text-white transition-colors">01</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Conecte e Mapeie</h3>
            <p class="text-slate-400 text-lg">Escaneie o QR Code e selecione os grupos que deseja monitorar.</p>
          </div>
        </div>

        <!-- Passo 2 -->
        <div class="group flex flex-col md:flex-row items-center gap-8">
          <div class="w-16 h-16 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0 group-hover:bg-target-green group-hover:text-white transition-colors">
            <span class="text-2xl font-black text-target-green group-hover:text-white transition-colors">02</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Defina os Alvos</h3>
            <p class="text-slate-400 text-lg">Escolha palavras-chave estratégicas como 'indicação', 'preciso de' ou 'ajuda'.</p>
          </div>
        </div>

        <!-- Passo 3 -->
        <div class="group flex flex-col md:flex-row items-center gap-8">
          <div class="w-16 h-16 rounded-2xl bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0 group-hover:bg-target-green group-hover:text-white transition-colors">
            <span class="text-2xl font-black text-target-green group-hover:text-white transition-colors">03</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-2">Abordagem Automática</h3>
            <p class="text-slate-400 text-lg">A IA entra em ação no privado do lead iniciando o funil de vendas.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SECURITY ==================== -->
    <SecuritySection />

    <!-- ==================== CTA FINAL ==================== -->
    <section class="py-24 px-4">
      <div class="relative max-w-4xl mx-auto bg-gradient-to-br from-target-green to-target-green-hover rounded-3xl p-12 text-center overflow-hidden">
        <!-- Ícone decorativo -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-10 pointer-events-none">
          <Target class="w-[200px] h-[200px]" />
        </div>

        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-black mb-6">
            Experimente 7 dias grátis
          </h2>
          <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
            A única ferramenta que coloca o lead no seu funil enquanto você dorme.
          </p>
          <a
            href="https://app.target-ia.com/login"
            class="cta-link inline-block bg-slate-950 text-white px-10 py-5 rounded-xl font-black text-xl hover:scale-105 transition-transform"
          >
            EXPERIMENTAR TARGET AI AGORA
          </a>
        </div>
      </div>
    </section>

  </div>

  <FooterBase />
</BaseLayout>
