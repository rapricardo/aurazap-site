---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavbarBase from '../components/NavbarBase.astro';
import FooterBase from '../components/FooterBase.astro';
import FAQ from '../components/FAQ.astro';
import { CheckCircle2, MessageSquare, Search, Zap, ShieldCheck, TrendingUp } from '@lucide/astro';
---

<BaseLayout
  title="Target AI — Captura Inteligente de Leads via WhatsApp"
  description="Sua IA de vendas que monitora grupos de WhatsApp 24/7. Identifica intenções de compra em tempo real e aborda o lead no direct automaticamente."
>
  <NavbarBase />

  <!-- ==================== HERO ==================== -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <!-- Background glows -->
    <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-target-green/10 rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-target-green/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left column -->
      <div class="relative z-10">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 glass rounded-full px-4 py-2 mb-8 text-sm text-slate-300">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-target-green opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-target-green"></span>
          </span>
          Monitoramento 24/7 Ativo
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          Sua IA de vendas que monitora grupos de WhatsApp <span class="text-target-green">24/7.</span>
        </h1>

        <p class="text-lg text-slate-400 leading-relaxed mb-8 max-w-xl">
          Identifica intenções de compra em tempo real e aborda o lead no direct automaticamente — antes da concorrência.
        </p>

        <a
          href="https://app.target-ia.com/login"
          class="btn-primary cta-link text-lg mb-4"
        >
          ATIVAR MEUS 7 DIAS GRÁTIS
        </a>

        <div class="flex items-center gap-2 text-sm text-slate-400 mt-4">
          <CheckCircle2 class="w-4 h-4 text-target-green shrink-0" />
          <span>Sem cartão de crédito. Configuração em 2 minutos.</span>
        </div>
      </div>

      <!-- Right column — Dashboard mockup -->
      <div class="relative z-10 hidden lg:block">
        <!-- Main dashboard card -->
        <div class="glass rounded-2xl p-6 shadow-2xl">
          <!-- Browser dots -->
          <div class="flex items-center gap-2 mb-6">
            <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
          </div>

          <!-- Dashboard content -->
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-slate-400 mb-1">Leads capturados hoje</p>
                <p class="text-3xl font-display font-bold text-white">47</p>
              </div>
              <div class="w-12 h-12 bg-target-green/20 rounded-xl flex items-center justify-center">
                <TrendingUp class="w-6 h-6 text-target-green" />
              </div>
            </div>

            <div class="h-px bg-white/10"></div>

            <!-- Fake stats row -->
            <div class="grid grid-cols-3 gap-4">
              <div>
                <p class="text-xs text-slate-500">Grupos</p>
                <p class="text-lg font-bold text-white">12</p>
              </div>
              <div>
                <p class="text-xs text-slate-500">Palavras-chave</p>
                <p class="text-lg font-bold text-white">38</p>
              </div>
              <div>
                <p class="text-xs text-slate-500">Taxa de resposta</p>
                <p class="text-lg font-bold text-target-green">92%</p>
              </div>
            </div>

            <!-- Fake activity bars -->
            <div class="space-y-2 pt-2">
              <div class="h-2 rounded-full bg-white/10 overflow-hidden">
                <div class="h-full w-4/5 bg-target-green rounded-full"></div>
              </div>
              <div class="h-2 rounded-full bg-white/10 overflow-hidden">
                <div class="h-full w-3/5 bg-target-green/70 rounded-full"></div>
              </div>
              <div class="h-2 rounded-full bg-white/10 overflow-hidden">
                <div class="h-full w-11/12 bg-target-green rounded-full"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Overlay chat mockup -->
        <div class="absolute -bottom-6 -left-8 glass rounded-2xl p-4 shadow-2xl w-72">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-target-green rounded-full flex items-center justify-center">
              <Zap class="w-4 h-4 text-white" />
            </div>
            <div>
              <p class="text-sm font-semibold text-white">Target AI Bot</p>
              <p class="text-xs text-target-green">Online agora</p>
            </div>
          </div>
          <div class="space-y-2">
            <div class="bg-white/10 rounded-xl rounded-tl-none px-3 py-2 text-xs text-slate-300 max-w-[85%]">
              Lead detectado no grupo "Empreendedores SP" — palavra-chave: <span class="text-target-green font-medium">"preciso de"</span>
            </div>
            <div class="bg-target-green/20 rounded-xl rounded-tr-none px-3 py-2 text-xs text-white ml-auto max-w-[85%]">
              Mensagem personalizada enviada no direct com sucesso.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PROBLEM ==================== -->
  <section class="py-24 bg-slate-950/50">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl lg:text-5xl text-center max-w-4xl mx-auto mb-16 leading-tight">
        Grupos de WhatsApp são minas de ouro, <span class="text-target-green">mas ninguém tem tempo de minerar.</span>
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="glass p-8 rounded-2xl hover:border-target-green/30 transition-all duration-300 group">
          <div class="w-12 h-12 bg-target-green/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-target-green/20 transition-colors">
            <Zap class="w-6 h-6 text-target-green" />
          </div>
          <h3 class="text-xl mb-3">Oportunidades perdidas</h3>
          <p class="text-slate-400 leading-relaxed">
            Você não viu a mensagem a tempo e o lead já fechou com outro.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="glass p-8 rounded-2xl hover:border-target-green/30 transition-all duration-300 group">
          <div class="w-12 h-12 bg-target-green/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-target-green/20 transition-colors">
            <MessageSquare class="w-6 h-6 text-target-green" />
          </div>
          <h3 class="text-xl mb-3">Poluição visual</h3>
          <p class="text-slate-400 leading-relaxed">
            Notificações infinitas que roubam seu foco e produtividade.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="glass p-8 rounded-2xl hover:border-target-green/30 transition-all duration-300 group">
          <div class="w-12 h-12 bg-target-green/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-target-green/20 transition-colors">
            <TrendingUp class="w-6 h-6 text-target-green" />
          </div>
          <h3 class="text-xl mb-3">Concorrência rápida</h3>
          <p class="text-slate-400 leading-relaxed">
            Sua concorrência chega antes de você em grupos de networking.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl lg:text-5xl text-center max-w-3xl mx-auto mb-16 leading-tight">
        Do setup à primeira venda em <span class="text-target-green">3 passos simples.</span>
      </h2>

      <div class="relative grid md:grid-cols-3 gap-12">
        <!-- Connector line -->
        <div class="hidden md:block absolute top-16 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-transparent via-target-green/40 to-transparent"></div>

        <!-- Step 1 -->
        <div class="text-center relative">
          <div class="w-16 h-16 rounded-full border-2 border-target-green flex items-center justify-center mx-auto mb-6 bg-target-bg shadow-[0_0_20px_rgba(0,166,126,0.2)] relative z-10">
            <span class="text-target-green font-display font-bold text-lg">01</span>
          </div>
          <h3 class="text-xl mb-3">Conecte e Mapeie</h3>
          <p class="text-slate-400 leading-relaxed">
            Escaneie o QR Code e selecione os grupos de networking ou comunidades que deseja monitorar.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="text-center relative">
          <div class="w-16 h-16 rounded-full border-2 border-target-green flex items-center justify-center mx-auto mb-6 bg-target-bg shadow-[0_0_20px_rgba(0,166,126,0.2)] relative z-10">
            <span class="text-target-green font-display font-bold text-lg">02</span>
          </div>
          <h3 class="text-xl mb-3">Defina os Alvos</h3>
          <p class="text-slate-400 leading-relaxed">
            Escolha as palavras-chave que indicam intenção (ex: 'indicação', 'preciso de', 'ajuda com').
          </p>
        </div>

        <!-- Step 3 -->
        <div class="text-center relative">
          <div class="w-16 h-16 rounded-full border-2 border-target-green flex items-center justify-center mx-auto mb-6 bg-target-bg shadow-[0_0_20px_rgba(0,166,126,0.2)] relative z-10">
            <span class="text-target-green font-display font-bold text-lg">03</span>
          </div>
          <h3 class="text-xl mb-3">Abordagem Automática</h3>
          <p class="text-slate-400 leading-relaxed">
            Assim que a palavra surge, a IA envia uma mensagem personalizada no privado do lead.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== DIFFERENTIALS ==================== -->
  <section class="py-24 bg-slate-950/50">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left column -->
      <div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl leading-tight mb-12">
          Diferenciais técnicos feitos para o <span class="text-target-green">Empresário Moderno.</span>
        </h2>

        <div class="grid sm:grid-cols-2 gap-6">
          <!-- Feature 1 -->
          <div class="glass p-6 rounded-2xl">
            <div class="w-10 h-10 bg-target-green/10 rounded-lg flex items-center justify-center mb-4">
              <CheckCircle2 class="w-5 h-5 text-target-green" />
            </div>
            <h3 class="text-lg mb-2">Leads Qualificados</h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              Você só fala com quem manifestou interesse explícito no que você oferece.
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="glass p-6 rounded-2xl">
            <div class="w-10 h-10 bg-target-green/10 rounded-lg flex items-center justify-center mb-4">
              <TrendingUp class="w-5 h-5 text-target-green" />
            </div>
            <h3 class="text-lg mb-2">Custo Zero de Tráfego</h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              Aproveite a audiência orgânica dos grupos que você já participa sem gastar com anúncios.
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="glass p-6 rounded-2xl">
            <div class="w-10 h-10 bg-target-green/10 rounded-lg flex items-center justify-center mb-4">
              <Zap class="w-5 h-5 text-target-green" />
            </div>
            <h3 class="text-lg mb-2">Velocidade de Resposta</h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              A IA aborda em milissegundos. No WhatsApp, quem responde primeiro, ganha a venda.
            </p>
          </div>

          <!-- Feature 4 -->
          <div class="glass p-6 rounded-2xl">
            <div class="w-10 h-10 bg-target-green/10 rounded-lg flex items-center justify-center mb-4">
              <ShieldCheck class="w-5 h-5 text-target-green" />
            </div>
            <h3 class="text-lg mb-2">Privacidade e Segurança</h3>
            <p class="text-sm text-slate-400 leading-relaxed">
              Conexão estável que simula o comportamento humano para proteger seu número.
            </p>
          </div>
        </div>
      </div>

      <!-- Right column — Decorative stat card -->
      <div class="flex items-center justify-center">
        <div class="relative aspect-square w-full max-w-md rounded-3xl bg-gradient-to-br from-target-green/20 via-transparent to-target-green/10 border border-target-green/20 flex flex-col items-center justify-center p-12">
          <!-- Watermark icon -->
          <Search class="absolute top-8 right-8 w-16 h-16 text-target-green/10" />

          <span class="text-7xl md:text-8xl font-display font-bold text-white mb-4">98%</span>
          <span class="text-lg text-slate-300 text-center leading-relaxed max-w-xs">
            Taxa de abertura em abordagens via Direct
          </span>

          <!-- Subtle glow -->
          <div class="absolute inset-0 rounded-3xl bg-target-green/5 blur-xl pointer-events-none"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <FAQ />

  <!-- ==================== FOOTER ==================== -->
  <FooterBase />
</BaseLayout>
